{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ApiSettings": {
    "XMLRequestsFolder": "Requests",
    "OpenSession": {
      "Endpoint": "http://localhost:8000/IFXService.svc/OpenSession",
      "XML": "OpenSession.xml",
      "Interval": 1440
    },
    "GetRealtimeNewsByProduct": {
      "Endpoint": "http://localhost:8000/IFXService.svc/GetRealtimeNewsByProduct",
      "XML": "GetRealtimeNewsByProduct.xml",
      "Interval": 60
    },
    "GetEntireNewsByID": {
      "Endpoint": "http://localhost:8000/IFXService.svc/GetEntireNewsByID",
      "XML": "GetEntireNewsByID.xml",
      "Interval": 0
    }
  },
  "RepositorySettings": {
    "RedisRepository": {
        "RedisConnection": "localhost:6379",
        "CleanupInterval": 7
    },
    "JsonRepository": {
        "JsonResultFolder": "JsonResult",
        "CleanupInterval": 30
    }
  }
}